# 单机试运营：PostgreSQL 运行在 docker-compose 的 postgres 服务中。
# 密码请使用 URL-safe 字符（字母、数字、-、_），不要留空。
POSTGRES_USER=shadowpm_app
POSTGRES_PASSWORD=
POSTGRES_DB=shadowpm
DATABASE_URL=postgresql://shadowpm_app:<replace-with-postgres-password>@postgres:5432/shadowpm?schema=public
SHADOWPM_SESSION_SECRET=
DEEPSEEK_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 仅首次创建团队管理员时临时设置，执行后立即从环境中移除
TEAM_ADMIN_NAME=
TEAM_ADMIN_EMAIL=
TEAM_ADMIN_PASSWORD=
# 仅创建普通成员时临时设置，执行后立即从环境中移除
TEAM_MEMBER_NAME=
TEAM_MEMBER_EMAIL=
TEAM_MEMBER_PASSWORD=
# 可选：MEMBER（默认）或 LEADER。只应由现有管理者创建 LEADER。
TEAM_MEMBER_ROLE=MEMBER
