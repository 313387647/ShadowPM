// ShadowPM - Prisma Schema
// 基于 DATABASE.md 蓝图，适配 Prisma 7.x

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  LEADER
  MEMBER
}

enum TaskStatus {
  PENDING // 待启动
  IN_PROGRESS // 进行中
  COMPLETED // 已完成
}

enum FlowType {
  ALLOCATE // 初始/追加预算 (正数)
  EXPENSE // 支出走账 (负数)
  REFUND // 费用退回 (正数)
}

/// Whether the project-level budget pool has been formally established.
/// The amount itself is held on Project.totalBudget; this enum makes its
/// business meaning explicit instead of inferring it from a synthetic flow.
enum ProjectBudgetStatus {
  UNCONFIRMED
  CONFIRMED
  CANCELED
}

/// Defines whether a project participates in budget management. It intentionally
/// does not infer intent from a zero amount: pending, unmanaged, and confirmed
/// budgets have different business meaning.
enum ProjectBudgetMode {
  PENDING
  CONFIRMED
  NOT_MANAGED
}

/// The current budget position of one control item. Detailed historical
/// movements are retained in BudgetFlow and surfaced through project activity.
enum TaskBudgetStatus {
  UNALLOCATED
  ALLOCATED
  APPROVED
  DISBURSED
  ACCEPTED
  CANCELED
}

/// The planning lifecycle of an independent budget item. Approval, transfers,
/// expenses, and refunds are append-only BudgetFlow actions rather than item
/// states, so users never have to decode a mixed financial workflow status.
enum BudgetItemStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  SETTLED
  CANCELED
}

enum BudgetItemSource {
  MANUAL
  AI_IMPORT
  MIGRATED
}

/// Canonical actions for newly created flows. The legacy string operation is
/// retained through the compatibility window so historical audit rows remain
/// unchanged and readable.
enum BudgetFlowAction {
  POOL_CONFIRMED
  POOL_ADJUSTED
  ITEM_CONFIRMED
  ITEM_ADJUSTED
  APPROVAL_RECORDED
  TRANSFER_RECORDED
  EXPENSE_RECORDED
  REFUND_RECORDED
  SETTLED
  CANCELED
  REVERSED
  LEGACY_IMPORTED
}

enum BudgetMigrationIssueType {
  OVER_POOL_LEGACY_ITEMS
  UNMAPPED_LEGACY_FLOW
  LEGACY_POOL_STATUS_AMBIGUOUS
}

enum ProjectMemberRole {
  EDITOR // 可编辑项目管控表、预算账本、执行日历
  VIEWER // 可查看项目，但不能修改
}

model User {
  id                 String            @id @default(cuid())
  name               String
  email              String            @unique
  passwordHash       String
  isActive           Boolean           @default(true)
  isExternalTester   Boolean           @default(false) // 外部体验账号：不进入团队管理与全局大盘
  role               Role              @default(MEMBER)
  createdAt          DateTime          @default(now())
  projects           Project[]
  feedbacks          ProjectFeedback[]
  projectMemberships ProjectMember[]
  projectFocuses     ProjectFocus[]
  sessions           AuthSession[]
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  ownerId     String
  totalBudget Decimal   @db.Decimal(14, 2) // 项目级预算池；预算模式决定 0 的业务含义
  budgetStatus ProjectBudgetStatus @default(UNCONFIRMED)
  budgetMode   ProjectBudgetMode @default(PENDING)
  budgetConfirmedAt DateTime?
  startDate   DateTime?
  endDate     DateTime?
  archivedAt  DateTime?
  isExternalProject Boolean @default(false) // 体验账号创建的隔离项目
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner           User                     @relation(fields: [ownerId], references: [id])
  tasks           Task[]
  phases          Phase[]
  calendarEntries ExecutionCalendarEntry[]
  activityLogs    ActivityLog[]
  feedbacks       ProjectFeedback[]
  members         ProjectMember[]
  sources         ProjectSource[]
  reports         ProjectReport[]
  shareLinks      ProjectShareLink[]
  focuses         ProjectFocus[]
  budgetFlows     BudgetFlow[]
  budgetItems     BudgetItem[]
  budgetMigrationIssues BudgetMigrationIssue[]

  @@index([ownerId])
  @@index([archivedAt])
  @@index([createdAt])
  @@index([budgetMode])
  @@index([isExternalProject])
}

/// A user-specific shortcut for projects that need sustained attention.
/// It does not grant access or editing permissions.
model ProjectFocus {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, createdAt])
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(EDITOR)
  createdBy String
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
}

model Phase {
  id        String    @id @default(cuid())
  projectId String
  name      String
  sortOrder Int       @default(0)
  startDate DateTime?
  endDate   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model Task {
  id                String     @id @default(cuid())
  projectId         String
  phaseId           String? // 所属阶段
  name              String
  description       String? // 详细描述（对标 Excel 管控表「详细描述」列）
  notes             String? // 进度备注/结论（对标 Excel「进度或结论」列）
  assignee          String? // 执行人姓名
  department        String? // 负责部门（对标 Excel「负责部门」列）
  priority          String     @default("P2") // P0 | P1 | P2 | P3
  sortOrder         Int        @default(0) // 项目内自定义排序；状态变化不影响此顺序
  deadline          DateTime?
  status            TaskStatus @default(PENDING)
  /// Legacy compatibility fields. New budget code must use BudgetItem and
  /// BudgetItemTaskRelation; these remain temporarily for safe data migration.
  budgetAmount      Decimal    @default(0) @db.Decimal(14, 2)
  budgetStatus      TaskBudgetStatus @default(UNALLOCATED)
  budgetRecipient   String?
  aiConfidence      String? // AI 导入行置信度：high | medium | low
  sourceRef         String? // AI 导入来源：文件/工作表/行列/段落
  missingFields     Json       @default("[]") // 可在管控表内补齐的字段
  conflicts         Json       @default("[]") // 源数据冲突或 AI 无法安全判断的信息
  needsConfirmation Boolean    @default(false) // 是否需要人工确认
  updatedAt         DateTime   @updatedAt

  project         Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           Phase?                   @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  logs            ProgressLog[]
  budgets         BudgetFlow[]
  budgetItemRelations BudgetItemTaskRelation[]
  calendarEntries ExecutionCalendarEntry[]

  @@index([projectId])
  @@index([phaseId])
  @@index([status])
  @@index([deadline])
  @@index([assignee])
  @@index([projectId, sortOrder])
  @@index([projectId, status, deadline])
}

/// A budget plan belongs to the project first. It may be associated with zero
/// or many control items, but a missing task must never prevent planning.
model BudgetItem {
  id            String           @id @default(cuid())
  projectId     String
  title         String
  category      String?
  plannedAmount Decimal          @db.Decimal(14, 2)
  status        BudgetItemStatus @default(DRAFT)
  description   String?
  source        BudgetItemSource @default(MANUAL)
  aiConfidence  String?
  sourceRef     String?
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  project       Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskRelations BudgetItemTaskRelation[]
  flows         BudgetFlow[]

  @@index([projectId, status])
  @@index([projectId, updatedAt])
  @@index([source])
}

/// Joining is explicit so one budget item can support several related control
/// items without making Task the financial source of truth.
model BudgetItemTaskRelation {
  budgetItemId String
  taskId       String
  createdAt    DateTime @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([budgetItemId, taskId])
  @@index([taskId])
}

model ProgressLog {
  id        String   @id @default(cuid())
  taskId    String
  content   String // 支持 Markdown
  createdBy String // 操作人
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([createdAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String
  targetType  String // PROJECT | CONTROL_ITEM | BUDGET_ITEM | CALENDAR_ENTRY | RISK | ASSET | IMPORT
  targetId    String?
  changeType  String // CREATE | UPDATE | STATUS_CHANGE | COMMENT | AI_ACTION | IMPORT | DELETE_REQUEST
  summary     String
  beforeState Json?
  afterState  Json?
  source      String   @default("HUMAN") // HUMAN | AI | IMPORT | SYSTEM
  createdBy   String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([targetType])
  @@index([createdAt])
  @@index([projectId, createdAt])
}

model BudgetFlow {
  id                 String   @id @default(cuid())
  projectId          String
  budgetItemId       String?
  taskId             String?
  counterpartyTaskId String?
  groupId            String?
  flowType           FlowType
  operation          String   @default("ALLOCATE") // CONFIRM_POOL | ADJUST_POOL | ALLOCATE | ADJUST | SPLIT_OUT | SPLIT_IN | APPROVE | DISBURSE | ACCEPT | CANCEL
  action             BudgetFlowAction?
  amount             Decimal  @db.Decimal(14, 2) // 当前动作对应金额；历史审计不参与余额计算
  counterparty       String?
  description        String // 事由
  createdBy          String
  createdAt          DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([taskId])
  @@index([budgetItemId, createdAt])
  @@index([action])
  @@index([counterpartyTaskId])
  @@index([groupId])
  @@index([operation])
  @@index([createdAt])
}

/// Exceptional migration records are explicit rather than silently assigning
/// legacy money to a wrong item. They are operational evidence, not a user
/// workflow surface.
model BudgetMigrationIssue {
  id        String                   @id @default(cuid())
  projectId String
  flowId    String?
  taskId    String?
  type      BudgetMigrationIssueType
  details   Json
  resolvedAt DateTime?
  createdAt DateTime                 @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, resolvedAt])
  @@index([flowId])
  @@index([taskId])
}

model ExecutionCalendarEntry {
  id         String    @id @default(cuid())
  projectId  String
  taskId     String?
  date       DateTime?
  startTime  String?
  endTime    String?
  channel    String?
  workstream String?
  content    String
  owner      String?
  department String?
  status     String    @default("PLANNED") // PLANNED | CONFIRMED | DONE | CANCELED
  notes      String?
  source     String    @default("MANUAL") // MANUAL | AI_IMPORT
  createdBy  String
  createdAt  DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([taskId])
  @@index([date])
  @@index([status])
  @@index([channel])
  @@index([projectId, date])
}

model ProjectFeedback {
  id            String   @id @default(cuid())
  projectId     String
  createdById   String
  testerName    String
  rating        Int
  aiAccuracy    String // GOOD | PARTIAL | POOR | NOT_TESTED
  uploadOutcome String // CREATED | CREATED_WITH_EDITS | FAILED | BLOCKED
  wouldUse      String // YES | MAYBE | NO
  budgetIssue   Boolean  @default(false)
  calendarIssue Boolean  @default(false)
  ownerIssue    Boolean  @default(false)
  missingInfo   Boolean  @default(false)
  friction      String?
  notes         String?
  createdAt     DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdById])
  @@index([createdAt])
  @@index([rating])
}

/// Source evidence retained from AI project import. This is grounding context,
/// not a standalone asset-management surface.
model ProjectSource {
  id            String   @id @default(cuid())
  projectId     String
  fileName      String
  mediaType     String
  sourceHash    String
  extractedText String   @db.Text
  uploadedBy    String
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([sourceHash])
  @@index([createdAt])
}

/// Persisted source-grounded weekly/monthly report for auditability.
model ProjectReport {
  id             String   @id @default(cuid())
  projectId      String
  periodType     String // WEEKLY | MONTHLY
  periodStart    DateTime
  periodEnd      DateTime
  content        String   @db.Text
  sourceSnapshot Json
  generatedBy    String
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([periodType])
  @@index([createdAt])
}

/// Revocable read-only share capability. Only a token hash is stored.
model ProjectShareLink {
  id        String    @id @default(cuid())
  projectId String
  tokenHash String    @unique
  label     String
  expiresAt DateTime?
  revokedAt DateTime?
  createdBy String
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
  @@index([revokedAt])
}
