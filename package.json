{
  "name": "shadow-pm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "npm run typecheck && npm run test:business",
    "test:business": "node --import tsx --test tests/business-rules.test.ts",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed:demo": "SHADOWPM_ALLOW_DEMO_SEED=1 prisma db seed",
    "team:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "team:create-member": "tsx scripts/create-team-member.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "next": "14.2.35",
    "openai": "^6.45.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^7.8.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
